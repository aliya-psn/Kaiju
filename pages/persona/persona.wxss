/* pages/persona/persona.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.result-card {
  padding: 48rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.persona-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin: 0 auto 32rpx;
  display: block;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.persona-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.result-placeholder {
  padding: 100rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

.actions {
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 200rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #FF6B9D 0%, #AF52DE 100%);
  color: #fff;
}

.action-btn::after {
  border: none;
}
