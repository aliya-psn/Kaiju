/* pages/fortune/fortune.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.result-card {
  padding: 60rpx 40rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.fortune-type {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.fortune-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #666;
}

.result-placeholder {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

.actions {
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 200rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #FF6B9D 0%, #AF52DE 100%);
  color: #fff;
}

.action-btn::after {
  border: none;
}
