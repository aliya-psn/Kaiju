<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部 Banner -->
  <view class="banner">
    <view class="banner-bg"></view>
    <view class="banner-shine"></view>
    <view class="banner-content">
      <text class="banner-tag">PARTY GAMES</text>
      <text class="banner-title">派对聚会趣味游戏</text>
      <text class="banner-desc">多人嗨玩 · 单人解闷</text>
    </view>
  </view>

  <!-- 多人游戏 -->
  <view class="section">
    <view class="section-tag multi">多人</view>
    <view class="section-title">聚会一起玩</view>
    <view class="game-cards">
      <view class="game-card" wx:for="{{multiGames}}" wx:key="id" 
            bindtap="onGameTap" data-id="{{item.id}}" data-type="multi">
        <view class="game-card-inner {{item.accent}}">
          <view class="game-icon-wrap">
            <image class="game-icon" src="/svg/{{item.icon}}" mode="aspectFit"/>
          </view>
          <view class="game-info">
            <text class="game-name">{{item.name}}</text>
            <text class="game-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 单人游戏 -->
  <view class="section">
    <view class="section-tag solo">单人</view>
    <view class="section-title">一个人也好玩</view>
    <view class="game-cards">
      <view class="game-card" wx:for="{{soloGames}}" wx:key="id" 
            bindtap="onGameTap" data-id="{{item.id}}" data-type="solo">
        <view class="game-card-inner {{item.accent}}">
          <view class="game-icon-wrap">
            <image class="game-icon" src="/svg/{{item.icon}}" mode="aspectFit"/>
          </view>
          <view class="game-info">
            <text class="game-name">{{item.name}}</text>
            <text class="game-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 邀请好友 -->
  <view class="invite-card card" bindtap="onShareTap">
    <view class="invite-content">
      <text class="invite-title">邀请好友一起玩</text>
      <text class="invite-desc">聚会游戏，人多才嗨</text>
    </view>
    <button class="invite-btn" open-type="share">
      <text>分享给好友</text>
    </button>
  </view>

  <view class="footer-tip">更多游戏即将上线 ~</view>
</view>
