/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
}

/* Banner - 精致版 */
.banner {
  position: relative;
  border-radius: 20rpx;
  padding: 48rpx 40rpx 52rpx;
  margin-bottom: 48rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(233, 30, 99, 0.2);
}

.banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #E91E63 0%, #9C27B0 50%, #7C4DFF 100%);
}

.banner-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(255,255,255,0.25) 0%, transparent 50%);
  pointer-events: none;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 16rpx;
}

.banner-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 2rpx;
}

/* Section */
.section {
  margin-bottom: 48rpx;
}

.section-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.section-tag.multi {
  background: rgba(233, 30, 99, 0.18);
  color: #C2185B;
}

.section-tag.solo {
  background: rgba(245, 0, 87, 0.15);
  color: #AD1457;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
  padding-left: 8rpx;
}

/* 游戏卡片 - 2列网格 */
.game-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.game-card {
  width: 48%;
  box-sizing: border-box;
}

.game-card-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  min-height: 120rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06), 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.game-card-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 100%);
  pointer-events: none;
}

.game-card-inner:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 多人 - 高饱和暖色 */
.game-card-inner.multi-1 {
  background: linear-gradient(145deg, #E91E63 0%, #FF80AB 100%);
}
.game-card-inner.multi-2 {
  background: linear-gradient(145deg, #00BFA5 0%, #64FFDA 100%);
}
.game-card-inner.multi-3 {
  background: linear-gradient(145deg, #7C4DFF 0%, #B388FF 100%);
}

/* 单人 */
.game-card-inner.solo-1 {
  background: linear-gradient(145deg, #FF6D00 0%, #FFAB40 100%);
}
.game-card-inner.solo-2 {
  background: linear-gradient(145deg, #F50057 0%, #FF8A80 100%);
}
.game-card-inner.solo-3 {
  background: linear-gradient(145deg, #0091EA 0%, #40C4FF 100%);
}

.game-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.28);
  border-radius: 14rpx;
  margin-right: 20rpx;
}

.game-icon {
  width: 38rpx;
  height: 38rpx;
  filter: brightness(1.05);
}

.game-info {
  flex: 1;
  min-width: 0;
}

.game-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
  line-height: 1.3;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.game-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.4;
  letter-spacing: 0.5rpx;
}

/* 邀请好友 */
.invite-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  margin-bottom: 48rpx;
}

.invite-content {
  flex: 1;
}

.invite-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.invite-desc {
  font-size: 26rpx;
  color: #999;
}

.invite-btn {
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #E91E63 0%, #7C4DFF 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  margin: 0;
  letter-spacing: 1rpx;
}

.invite-btn::after {
  border: none;
}

/* Footer */
.footer-tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding-top: 24rpx;
}
