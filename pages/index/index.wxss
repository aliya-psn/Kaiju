/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
}

/* Banner - 精致版 */
.banner {
  position: relative;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 52rpx;
  margin-bottom: 48rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #FF6B9D 0%, #E85D8F 40%, #AF52DE 100%);
}

.banner-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(255,255,255,0.25) 0%, transparent 50%);
  pointer-events: none;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 16rpx;
}

.banner-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 2rpx;
}

/* Section */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
  padding-left: 8rpx;
}

/* 游戏卡片 - 2列网格 */
.game-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 28rpx;
  margin-bottom: 56rpx;
}

.game-card {
  width: 48%;
  box-sizing: border-box;
}

.game-card-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  min-height: 150rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s ease;
}

.game-card-inner:active {
  transform: scale(0.98);
}

.game-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 18rpx;
  margin-right: 22rpx;
}

.game-icon {
  width: 50rpx;
  height: 50rpx;
}

.game-info {
  flex: 1;
  min-width: 0;
}

.game-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.game-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.35;
}

/* 头像滚动 */
.avatar-scroll {
  white-space: nowrap;
  margin-bottom: 64rpx;
}

.avatar-list {
  display: inline-flex;
  gap: 40rpx;
  padding: 24rpx 0;
}

.avatar-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background: #F5F5F5;
}

.avatar-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 16rpx;
  max-width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Footer */
.footer-tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding-top: 24rpx;
}
