/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* Banner */
.banner {
  position: relative;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF9A8B 100%);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 48rpx;
  overflow: hidden;
}

.banner-decoration {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.banner-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* Section */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

/* 游戏卡片 */
.game-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.game-card {
  overflow: hidden;
}

.game-card-inner {
  display: flex;
  align-items: center;
  padding: 36rpx;
  border-radius: 24rpx;
  min-height: 160rpx;
}

.game-icon {
  width: 100rpx;
  height: 100rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.game-info {
  flex: 1;
}

.game-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.game-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 头像滚动 */
.avatar-scroll {
  white-space: nowrap;
  margin-bottom: 48rpx;
}

.avatar-list {
  display: inline-flex;
  gap: 32rpx;
  padding: 16rpx 0;
}

.avatar-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background: #F5F5F5;
}

.avatar-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
  max-width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Footer */
.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
