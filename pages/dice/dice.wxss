/* pages/dice/dice.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 骰子舞台 */
.stage {
  position: relative;
  width: 100%;
  height: 440rpx;
  margin-bottom: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 800rpx;
}

/* 底座 */
.stage-base {
  position: absolute;
  bottom: 0;
  width: 560rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #8B7355 0%, #6B5344 100%);
  border-radius: 10rpx;
  box-shadow: 
    0 8rpx 0 #5a4638,
    0 16rpx 32rpx rgba(0,0,0,0.2);
}

/* 骰子托盘 - 上2下3 */
.dice-tray {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  padding-bottom: 32rpx;
  opacity: 0;
  transform: scale(0.9);
  transition: opacity 0.4s ease, transform 0.4s ease;
  z-index: 1;
}

.dice-row {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.dice-tray.revealed {
  opacity: 1;
  transform: scale(1);
}

.dice-tray.shaking {
  animation: trayShake 0.5s ease;
}

@keyframes trayShake {
  0%, 100% { transform: scale(1) translateX(0); }
  20% { transform: scale(1.02) translateX(-8rpx); }
  40% { transform: scale(1.02) translateX(8rpx); }
  60% { transform: scale(1.01) translateX(-6rpx); }
  80% { transform: scale(1.01) translateX(6rpx); }
}

/* 3D 立体骰子 - 实物立方体 */
.dice-3d {
  perspective: 400rpx;
}

.dice-box {
  width: 72rpx;
  height: 72rpx;
  position: relative;
  transform-style: preserve-3d;
  transform: rotateX(-20deg) rotateY(8deg) rotateZ(-3deg);
  border-radius: 10rpx;
  box-shadow: 
    3rpx 3rpx 0 #c8c8c8,
    6rpx 6rpx 0 #b8b8b8,
    9rpx 9rpx 0 #a8a8a8,
    0 12rpx 24rpx rgba(0,0,0,0.25),
    inset 2rpx 2rpx 0 rgba(255,255,255,0.9),
    inset -1rpx -1rpx 0 rgba(0,0,0,0.05);
  background: linear-gradient(150deg, #fffef9 0%, #f8f6f0 30%, #f0ede6 70%, #e8e4dc 100%);
  transition: transform 0.3s ease;
}

.dice-box:active {
  transform: rotateX(-20deg) rotateY(8deg) rotateZ(-3deg) scale(0.98);
}

.dice-face {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  position: relative;
}

/* 点数 - 红/黑 */
.pip {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  opacity: 0;
  box-shadow: 
    0 1rpx 2rpx rgba(0,0,0,0.3),
    inset 0 1rpx 0 rgba(255,255,255,0.2);
}

.dice-3d.red .pip {
  background: #c62828;
}

.dice-3d.black .pip {
  background: #1a1a1a;
}

.p1 { top: 14rpx; left: 14rpx; }
.p2 { top: 14rpx; left: 50%; transform: translateX(-50%); }
.p3 { top: 14rpx; right: 14rpx; }
.p4 { top: 50%; left: 14rpx; transform: translateY(-50%); }
.p5 { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.p6 { top: 50%; right: 14rpx; transform: translateY(-50%); }
.p7 { bottom: 14rpx; left: 14rpx; }
.p8 { bottom: 14rpx; left: 50%; transform: translateX(-50%); }
.p9 { bottom: 14rpx; right: 14rpx; }

.dice-1 .p5 { opacity: 1; }
.dice-2 .p1, .dice-2 .p9 { opacity: 1; }
.dice-3 .p1, .dice-3 .p5, .dice-3 .p9 { opacity: 1; }
.dice-4 .p1, .dice-4 .p3, .dice-4 .p7, .dice-4 .p9 { opacity: 1; }
.dice-5 .p1, .dice-5 .p3, .dice-5 .p5, .dice-5 .p7, .dice-5 .p9 { opacity: 1; }
.dice-6 .p1, .dice-6 .p3, .dice-6 .p4, .dice-6 .p6, .dice-6 .p7, .dice-6 .p9 { opacity: 1; }

/* 立体碗 */
.bowl-wrap {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bowl-wrap.closed {
  transform: translateX(-50%) translateY(0) scale(1);
  opacity: 1;
}

.bowl-wrap.open {
  transform: translateX(-50%) translateY(-320rpx) scale(0.75);
  opacity: 0;
  pointer-events: none;
}

.bowl {
  position: relative;
  width: 520rpx;
  height: 280rpx;
}

/* 碗身：倒扣半球 - 装5颗骰子 */
.bowl-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 280rpx;
  background: radial-gradient(ellipse 250rpx 280rpx at 50% 100%, #5a5a5a 0%, #454545 25%, #333 55%, #222 85%, #1a1a1a 100%);
  border-radius: 50% 50% 0 0;
  box-shadow: 
    inset 0 60rpx 100rpx rgba(0,0,0,0.45),
    inset 0 -40rpx 60rpx rgba(255,255,255,0.06),
    0 14rpx 0 #4a4a4a,
    0 24rpx 60rpx rgba(0,0,0,0.4),
    0 4rpx 0 rgba(255,255,255,0.03);
}

.bowl-rim {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 520rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #666 0%, #4a4a4a 40%, #353535 80%, #2a2a2a 100%);
  border-radius: 14rpx;
  box-shadow: 
    0 6rpx 12rpx rgba(0,0,0,0.4),
    inset 0 2rpx 0 rgba(255,255,255,0.2),
    inset 0 -2rpx 0 rgba(0,0,0,0.2);
}

/* 操作按钮 - 统一风格 */
.actions {
  width: 100%;
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 160rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4CD964 0%, #5AC8FA 100%);
  color: #fff;
}

.action-btn:not(.primary) {
  background: #fff;
  color: #4CD964;
  border-color: #4CD964;
}
