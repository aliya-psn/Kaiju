/* pages/dice/dice.wxss - 与 wordgen 统一风格 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 80rpx;
}

/* Header - 与 wordgen 一致 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-badge {
  display: inline-block;
  background: linear-gradient(135deg, #4CD964 0%, #5AC8FA 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(76, 217, 100, 0.4);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 4rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 骰子/杯子卡片 */
.dice-card {
  padding: 48rpx;
  margin-bottom: 40rpx;
  min-height: 320rpx;
}

.dice-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.dice-area.cup-mode {
  animation: fadeIn 0.3s ease;
}

.dice-area.dice-mode {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.cup-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cup-img {
  width: 240rpx;
}

.cup-hint {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
}

.dice-wrap {
  display: flex;
  gap: 48rpx;
  justify-content: center;
  align-items: center;
}

.dice {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(135deg, #fff 0%, #F8F4F0 100%);
  border-radius: 20rpx;
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    0 0 0 1rpx rgba(0, 0, 0, 0.04);
}

.dice.shaking {
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: rotate(0) scale(1); }
  15% { transform: rotate(-12deg) scale(1.08); }
  30% { transform: rotate(12deg) scale(1.04); }
  45% { transform: rotate(-8deg) scale(1.06); }
  60% { transform: rotate(8deg) scale(1.02); }
  75% { transform: rotate(-4deg) scale(1.02); }
}

.dice-face {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  position: relative;
}

.pip {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  background: #FF6B9D;
  border-radius: 50%;
  opacity: 0;
  transition: opacity 0.2s;
}

.p1 { top: 22rpx; left: 22rpx; }
.p2 { top: 22rpx; left: 50%; transform: translateX(-50%); }
.p3 { top: 22rpx; right: 22rpx; }
.p4 { top: 50%; left: 22rpx; transform: translateY(-50%); }
.p5 { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.p6 { top: 50%; right: 22rpx; transform: translateY(-50%); }
.p7 { bottom: 22rpx; left: 22rpx; }
.p8 { bottom: 22rpx; left: 50%; transform: translateX(-50%); }
.p9 { bottom: 22rpx; right: 22rpx; }

.dice-1 .p5 { opacity: 1; }
.dice-2 .p1, .dice-2 .p9 { opacity: 1; }
.dice-3 .p1, .dice-3 .p5, .dice-3 .p9 { opacity: 1; }
.dice-4 .p1, .dice-4 .p3, .dice-4 .p7, .dice-4 .p9 { opacity: 1; }
.dice-5 .p1, .dice-5 .p3, .dice-5 .p5, .dice-5 .p7, .dice-5 .p9 { opacity: 1; }
.dice-6 .p1, .dice-6 .p3, .dice-6 .p4, .dice-6 .p6, .dice-6 .p7, .dice-6 .p9 { opacity: 1; }

.dice-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 - 与 wordgen 一致 */
.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.shake-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CD964 0%, #5AC8FA 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 217, 100, 0.4);
}

.shake-btn::after {
  border: none;
}

.shake-btn[disabled] {
  opacity: 0.5;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.cover-btn {
  padding: 20rpx 48rpx;
  background: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #eee;
}

.tip-text {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
