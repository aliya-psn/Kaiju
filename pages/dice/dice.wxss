/* pages/dice/dice.wxss */
page {
  height: 100%;
  overflow: hidden;
}

.page-wrap {
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0D1117 0%, #161B22 40%, #21262D 100%);
}

/* 顶部标题 */
.header {
  flex-shrink: 0;
  padding: 32rpx 40rpx 24rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 2rpx;
}

/* 主内容区 */
.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 32rpx;
  min-height: 0;
}

/* 骰子舞台 */
.stage {
  position: relative;
  width: 100%;
  height: 420rpx;
  max-height: 50vh;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 900rpx;
}

/* 底座 - 浅色陶瓷盘，与碗配套 */
.stage-base {
  position: absolute;
  bottom: 0;
  width: 560rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #E4E0D8 0%, #D0CCC4 40%, #B8B4AC 100%);
  border-radius: 14rpx;
  box-shadow:
    0 4rpx 0 rgba(255, 255, 255, 0.4),
    0 12rpx 36rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6);
}

/* 骰子托盘 */
.dice-tray {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 18rpx;
  padding-bottom: 28rpx;
  opacity: 0;
  transform: scale(0.88);
  transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1), transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  z-index: 1;
}

.dice-row {
  display: flex;
  gap: 26rpx;
  justify-content: center;
}

.dice-tray.revealed {
  opacity: 1;
  transform: scale(1);
}

.dice-tray.shaking {
  animation: trayShake 0.5s ease;
}

@keyframes trayShake {
  0%, 100% { transform: scale(1) translateX(0); }
  25% { transform: scale(1.02) translateX(-10rpx); }
  50% { transform: scale(1.02) translateX(10rpx); }
  75% { transform: scale(1.01) translateX(-6rpx); }
}

/* 3D 骰子 - 立体高级感 */
.dice-3d {
  perspective: 500rpx;
}

.dice-box {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  transform-style: preserve-3d;
  transform: rotateX(-28deg) rotateY(12deg) rotateZ(-5deg);
  border-radius: 12rpx;
  box-shadow:
    2rpx 2rpx 0 rgba(255, 255, 255, 0.6),
    4rpx 4rpx 0 rgba(255, 255, 255, 0.3),
    0 4rpx 0 #D0CCC4,
    4rpx 8rpx 0 #C0BCB4,
    8rpx 12rpx 0 #B0ACA4,
    0 16rpx 40rpx rgba(0, 0, 0, 0.4),
    inset 2rpx 2rpx 0 rgba(255, 255, 255, 0.95),
    inset -2rpx -2rpx 0 rgba(0, 0, 0, 0.06);
  background: linear-gradient(155deg, #FFFEF9 0%, #F8F5EF 25%, #EDE9E2 60%, #E2DED6 100%);
  transition: transform 0.3s ease;
}

.dice-face {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  position: relative;
}

/* 点数 - 大且醒目 */
.pip {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  opacity: 0;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
}

.dice-3d.red .pip {
  background: radial-gradient(circle at 30% 30%, #FF5252, #C62828 60%, #B71C1C 100%);
}

.dice-3d.black .pip {
  background: radial-gradient(circle at 30% 30%, #546E7A, #37474F 60%, #263238 100%);
}

.p1 { top: 10rpx; left: 10rpx; }
.p2 { top: 10rpx; left: 50%; transform: translateX(-50%); }
.p3 { top: 10rpx; right: 10rpx; }
.p4 { top: 50%; left: 10rpx; transform: translateY(-50%); }
.p5 { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.p6 { top: 50%; right: 10rpx; transform: translateY(-50%); }
.p7 { bottom: 10rpx; left: 10rpx; }
.p8 { bottom: 10rpx; left: 50%; transform: translateX(-50%); }
.p9 { bottom: 10rpx; right: 10rpx; }

.dice-1 .p5 { opacity: 1; }
.dice-2 .p1, .dice-2 .p9 { opacity: 1; }
.dice-3 .p1, .dice-3 .p5, .dice-3 .p9 { opacity: 1; }
.dice-4 .p1, .dice-4 .p3, .dice-4 .p7, .dice-4 .p9 { opacity: 1; }
.dice-5 .p1, .dice-5 .p3, .dice-5 .p5, .dice-5 .p7, .dice-5 .p9 { opacity: 1; }
.dice-6 .p1, .dice-6 .p3, .dice-6 .p4, .dice-6 .p6, .dice-6 .p7, .dice-6 .p9 { opacity: 1; }

/* 倒扣碗 - 浅色陶瓷，与深色背景对比 */
.bowl-wrap {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  transition: all 0.5s cubic-bezier(0.34, 1.4, 0.64, 1);
}

.bowl-wrap.closed {
  transform: translateX(-50%) translateY(0) scale(1);
  opacity: 1;
}

.bowl-wrap.open {
  transform: translateX(-50%) translateY(-300rpx) scale(0.72);
  opacity: 0;
  pointer-events: none;
}

.bowl {
  position: relative;
  width: 480rpx;
  height: 260rpx;
}

.bowl-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 460rpx;
  height: 260rpx;
  background: radial-gradient(ellipse 230rpx 260rpx at 50% 100%, #E8E4DC 0%, #D8D4CC 25%, #C8C4BC 55%, #B8B4AC 85%, #A8A49C 100%);
  border-radius: 50% 50% 0 0;
  box-shadow:
    inset 0 40rpx 60rpx rgba(255, 255, 255, 0.5),
    inset 0 -30rpx 50rpx rgba(0, 0, 0, 0.08),
    0 8rpx 0 rgba(255, 255, 255, 0.4),
    0 16rpx 48rpx rgba(0, 0, 0, 0.5);
}

.bowl-rim {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 480rpx;
  height: 24rpx;
  background: linear-gradient(180deg, #E0DCD4 0%, #C8C4BC 50%, #B0ACA4 100%);
  border-radius: 12rpx;
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

/* 操作按钮 - 正圆形 */
.actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  gap: 40rpx;
  padding: 28rpx 0;
}

.action-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.action-btn text {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1;
}

.action-btn.primary {
  background: linear-gradient(135deg, #00BFA5 0%, #64FFDA 100%);
  box-shadow: 0 8rpx 28rpx rgba(0, 191, 165, 0.4);
}

.action-btn.primary text {
  color: #fff;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.action-btn.secondary text {
  color: #fff;
}
