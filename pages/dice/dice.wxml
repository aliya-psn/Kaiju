<!--pages/dice/dice.wxml - 酒筛子-->
<view class="page-wrap">
  <view class="header">
    <text class="header-title">酒筛子</text>
    <text class="header-desc">摇一摇 · 扣碗开</text>
  </view>

  <view class="container">
    <view class="stage" bindtap="onToggleCover">
      <view class="stage-base"></view>
      <view class="dice-tray {{!covered ? 'revealed' : ''}} {{shaking ? 'shaking' : ''}}">
      <view class="dice-row" wx:for="{{diceRows}}" wx:for-index="ri" wx:key="ri">
        <view class="dice-3d {{(ri + ii) % 2 === 0 ? 'red' : 'black'}}" wx:for="{{item}}" wx:for-item="val" wx:for-index="ii" wx:key="ii">
          <view class="dice-box">
            <view class="dice-face dice-{{val}}">
              <view class="pip p1"></view>
              <view class="pip p2"></view>
              <view class="pip p3"></view>
              <view class="pip p4"></view>
              <view class="pip p5"></view>
              <view class="pip p6"></view>
              <view class="pip p7"></view>
              <view class="pip p8"></view>
              <view class="pip p9"></view>
            </view>
          </view>
        </view>
      </view>
      </view>
      <view class="bowl-wrap {{covered ? 'closed' : 'open'}}">
      <view class="bowl">
        <view class="bowl-body"></view>
        <view class="bowl-rim"></view>
      </view>
      </view>
    </view>

    <view class="actions">
      <view class="action-btn primary" bindtap="onShake" wx:if="{{covered}}"><text>摇</text></view>
      <view class="action-btn secondary" bindtap="onToggleCover" wx:else><text>扣</text></view>
    </view>
  </view>
</view>
