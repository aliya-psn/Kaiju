/* pages/decide/decide.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.preset-scroll {
  white-space: nowrap;
  margin-bottom: 32rpx;
}

.preset-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.preset-tab {
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.preset-tab.active {
  background: linear-gradient(135deg, #4CD964 0%, #5AC8FA 100%);
  color: #fff;
}

.result-card {
  padding: 60rpx 40rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.result-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.result-placeholder {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

.actions {
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 200rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #4CD964 0%, #5AC8FA 100%);
  color: #fff;
}

.action-btn::after {
  border: none;
}
