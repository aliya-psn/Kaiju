/* pages/turtle/turtle.wxss */
.container {
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

/* 题目卡片 */
.story-card {
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.story-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.story-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #333;
}

.story-placeholder {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}

/* 答案卡片 */
.answer-card {
  padding: 0 40rpx 40rpx;
  margin-bottom: 40rpx;
}

.answer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #eee;
}

.answer-label {
  font-size: 28rpx;
  color: #AF52DE;
  font-weight: 600;
}

.answer-arrow {
  font-size: 24rpx;
  color: #999;
}

.answer-content {
  padding-top: 28rpx;
}

.answer-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: #666;
}

/* 操作 */
.actions {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.action-btn {
  width: 160rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #AF52DE 0%, #FF6B9D 100%);
  color: #fff;
}

/* 玩法 */
.tips-card {
  padding: 28rpx 36rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
